// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/// Пользователь приложения (регистрация / авторизация и профиль).
model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  /// Хеш пароля (например bcrypt / argon2). Пароль в открытом виде не храним.
  passwordHash       String
  name               String
  /// Уникальный никнейм (вход по нику или по e-mail).
  nickname           String?  @unique
  /// URL аватара (внешняя ссылка или путь из /public).
  avatar             String?
  profileDescription String?
  city               String?
  /// Дата регистрации («присоединился»).
  createdAt          DateTime @default(now())
  /// Денормализованное число подписчиков; при появлении модели Follow можно считать через связи.
  followersCount     Int      @default(0)
  /// Количество прогулок (или связь с моделью Walk позже).
  walksCount         Int      @default(0)
  rating             Float    @default(0)
  /// Избранное: JSON-массив идентификаторов (места, маршруты и т.д.).
  favorites          Json     @default("[]")
  walks              Walk[]

  @@map("users")
}

/// Прогулка, созданная пользователем в планировщике.
model Walk {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  city            String
  description     String?
  theme           String?
  pace            String?
  travelModeId    String
  timeStart       String?
  timeEnd         String?
  distanceKm      Float
  durationMinutes Int
  coverImage      String?
  waypoints       Json
  path            Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
  @@map("walks")
}
